{
    // 1. VISUAL HIDER: This hides the messy binary folder from your sidebar
    "files.exclude": {
        "**/bin": true,
        "**/*.out": true,
        "**/*.dSYM": true,
        "**/.DS_Store": true
    },

    // 2. THE CLEAN RUNNER: Creates a hidden 'bin' folder and puts the executable there
    "code-runner.executorMap": {
        "cpp": "cd $dir && mkdir -p bin && clang++ -std=c++17 $fileName -o bin/$fileNameWithoutExt && ./bin/$fileNameWithoutExt"
    },

    // 3. BEST PRACTICES: Run in terminal and auto-save
    "code-runner.runInTerminal": true,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.clearPreviousOutput": true,
    "code-runner.preserveFocus": false
}